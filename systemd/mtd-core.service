[Unit]
Description=MTD Core (heartbeat, WebSocket, OTA-updates, statuspagina)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/mtd-agent/agent
ExecStart=/opt/mtd-agent/venv/bin/python core.py
Restart=always
RestartSec=5
Environment=MTD_CONFIG=/opt/mtd-agent/config.json
Environment=MTD_STATE=/opt/mtd-agent/state.json
Environment=MTD_SIGNALS=/opt/mtd-agent/signals.json
Environment=MTD_API_URL=http://192.168.0.109:8000
Environment=MTD_WS_URL=ws://192.168.0.109:8000/agent/ws
Environment=MTD_PLUGIN_DIR=/opt/mtd-agent/agent/integrations

[Install]
WantedBy=multi-user.target
