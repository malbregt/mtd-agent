[Unit]
Description=MTD Worker (integraties pollen, cachen en synchroniseren)
After=network-online.target mtd-core.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/mtd-agent/agent
ExecStart=/opt/mtd-agent/venv/bin/python worker.py
Restart=always
RestartSec=10
Environment=MTD_CONFIG=/opt/mtd-agent/config.json
Environment=MTD_DB=/opt/mtd-agent/cache.db
Environment=MTD_STATE=/opt/mtd-agent/state.json
Environment=MTD_SIGNALS=/opt/mtd-agent/signals.json
Environment=MTD_PLUGIN_DIR=/opt/mtd-agent/agent/integrations
# Optioneel per-device bestand om MTD_API_URL te overrulen (zie mtd-core.service).
EnvironmentFile=-/etc/mtd-agent/env

[Install]
WantedBy=multi-user.target
